class Solution:
    def isPalindrome(self, s: str) -> bool:

        s = ''.join([char for char in s if char.isalnum()])
        s = s.lower()
        if s==" ":
            return True

        n = len(s)
        i,j = 0,n-1
        while (i<j):
            if s[i] != s[j]:
                return False
            i = i+1
            j = j-1
        
        return True
